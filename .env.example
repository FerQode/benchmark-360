# .env.example
# ─────────────────────────────────────────────────────────
# Copiar a .env y completar con valores reales
# NUNCA commitear .env al repositorio
# ─────────────────────────────────────────────────────────

# OpenAI API Key (OBLIGATORIO)
OPENAI_API_KEY=sk-...

# Gemini API Key (OBLIGATORIO si usas Gemini)
GEMINI_API_KEY=AIzaSy...

# Mistral API Key (Opcional, para Tier 2 Pixtral Vision)
MISTRAL_API_KEY=
MISTRAL_MODEL_VISION=pixtral-12-2409

# Configuración de Proveedores LLM
PRIMARY_LLM_PROVIDER=auto  # Opciones: openai, gemini, auto (intenta openai, si falla usa gemini)

# Modelos LLM a usar (OpenAI)
LLM_TEXT_MODEL=gpt-4o-mini
LLM_VISION_MODEL=gpt-4o

# Modelos LLM a usar (Gemini)
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# Configuración de scraping
SCRAPING_DELAY_MIN=2.0
SCRAPING_DELAY_MAX=5.0
SCRAPING_MAX_RETRIES=3
SCRAPING_TIMEOUT=30

# Paths de datos
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_OUTPUT_PATH=data/output

# Logging
LOG_LEVEL=INFO
LOG_FILE=data/pipeline.log

# Modo de ejecución
DRY_RUN=false
